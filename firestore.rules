rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    // Any logged-in user can read user profiles (needed for assignment lists)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == 'tarekmoh123@gmail.com'
      );
      allow delete: if request.auth.token.email == 'tarekmoh123@gmail.com';
    }

    // ─── Correspondences ──────────────────────────────────────────────────────
    match /correspondences/{id} {
      allow read, write: if request.auth != null;
    }

    // ─── Tasks ────────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }

    // ─── Milestones ───────────────────────────────────────────────────────────
    match /milestones/{id} {
      allow read, write: if request.auth != null;
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
// Force upload by changing hash 1
