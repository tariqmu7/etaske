# Copy to .env (gitignored) and fill in real values. VITE_-prefixed vars are
# embedded into the static client bundle, so treat them as public-ish: they
# raise the bar against drive-by abuse but are not true secrets.

# Google Apps Script web-app URL used for Drive uploads + the FCM push proxy.
# Required for file uploads to work.
VITE_GOOGLE_SCRIPT_URL=

# Shared secret that must match the SHARED_SECRET Script Property on the Apps
# Script deployment. Gates the upload/push endpoint against anonymous abuse.
# Set the SAME value here, in the GitHub Actions secret of the same name, and in
# the Apps Script Project Settings -> Script Properties.
VITE_GOOGLE_SCRIPT_SECRET=

# Web push (FCM) VAPID public key from Firebase console -> Cloud Messaging.
VITE_FIREBASE_VAPID_KEY=

# Unused at runtime (vestigial AI Studio scaffold); kept for parity.
GEMINI_API_KEY=
APP_URL=
